class Solution {
    public long maximumBooks(int[] books) {
        int n = books.length;
        long ans = 0;

        for (int i = 0; i < n; i++) {
            long sum = 0;
            int prev = books[i];

            for (int j = i; j >= 0 && prev > 0; j--) {
                int take = Math.min(books[j], prev);
                sum += take;
                prev = take - 1;
            }

            ans = Math.max(ans, sum);
        }

        return ans;
    }
}
