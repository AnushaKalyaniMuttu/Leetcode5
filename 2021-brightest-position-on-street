class Solution {
    public int subarrayBitwiseORs(int[] nums) {
        Set<Integer> result = new HashSet<>();
        Set<Integer> prev = new HashSet<>();
        
        for (int num : nums) {
            Set<Integer> curr = new HashSet<>();
            // add the current number as a one‑element subarray
            curr.add(num);
            // extend all previous ORs with current number
            for (int val : prev) {
                curr.add(val | num);
            }
            // add all these to the global result
            result.addAll(curr);
            // move current set to prev for next iteration
            prev = curr;
        }
        
        return result.size();
    }
}
