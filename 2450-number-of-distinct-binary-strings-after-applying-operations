class Solution {
    static final long MOD = 1_000_000_007L;

    public int countDistinct(String s, int k) {
        int n = s.length();

        long ans = 1;
        int cnt = n - k + 1;

        for (int i = 0; i < cnt; i++) {
            ans = (ans * 2) % MOD;
        }

        return (int) ans;
    }
}
