class Solution {

    public int longestNiceSubarray(int[] nums) {

        int mask = 0;
        int left = 0;
        int res = 0;

        for (int right = 0; right < nums.length; right++) {

            while ((mask & nums[right]) != 0) {
                mask ^= nums[left];
                left++;
            }

            mask |= nums[right];

            res = Math.max(res, right - left + 1);
        }

        return res;
    }
}
