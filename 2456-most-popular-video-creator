import java.util.*;

class Solution {
    public List<List<String>> mostPopularCreator(String[] creators, String[] ids, int[] views) {
        Map<String, Long> totalViews = new HashMap<>();
        Map<String, Video> bestVideo = new HashMap<>();

        for (int i = 0; i < creators.length; i++) {
            String creator = creators[i];
            String id = ids[i];
            int view = views[i];

            totalViews.put(creator, totalViews.getOrDefault(creator, 0L) + view);

            if (!bestVideo.containsKey(creator)) {
                bestVideo.put(creator, new Video(id, view));
            } else {
                Video cur = bestVideo.get(creator);
                if (view > cur.views || (view == cur.views && id.compareTo(cur.id) < 0)) {
                    bestVideo.put(creator, new Video(id, view));
                }
            }
        }

        long maxTotal = 0;
        for (long total : totalViews.values()) {
            maxTotal = Math.max(maxTotal, total);
        }

        List<List<String>> ans = new ArrayList<>();
        for (String creator : totalViews.keySet()) {
            if (totalViews.get(creator) == maxTotal) {
                ans.add(Arrays.asList(creator, bestVideo.get(creator).id));
            }
        }

        return ans;
    }

    static class Video {
        String id;
        int views;

        Video(String id, int views) {
            this.id = id;
            this.views = views;
        }
    }
}
