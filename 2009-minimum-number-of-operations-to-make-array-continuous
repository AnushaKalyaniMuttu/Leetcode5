import java.util.*;

class Solution {
    public int minOperations(int[] nums) {
        int n = nums.length;

        Arrays.sort(nums);

        // remove duplicates
        int[] unique = Arrays.stream(nums).distinct().toArray();

        int ans = n;
        int j = 0;

        for (int i = 0; i < unique.length; i++) {
            while (j < unique.length && unique[j] < unique[i] + n) {
                j++;
            }

            int window = j - i;
            ans = Math.min(ans, n - window);
        }

        return ans;
    }
}
