class Solution {
    public long getDescentPeriods(int[] prices) {
        long result = 0;
        long streak = 1; // at least 1 (single element)

        for (int i = 0; i < prices.length; i++) {
            if (i > 0 && prices[i] == prices[i - 1] - 1) {
                streak++;
            } else {
                streak = 1;
            }

            result += streak;
        }

        return result;
    }
}
