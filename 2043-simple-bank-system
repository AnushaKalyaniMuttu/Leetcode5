class Bank {
    private long[] balances;

    public Bank(long[] balance) {
        this.balances = balance;
    }

    private boolean valid(int account) {
        return account >= 1 && account <= balances.length;
    }

    public boolean transfer(int from, int to, long amount) {
        if (!valid(from) || !valid(to)) return false;
        if (balances[from - 1] < amount) return false;
        balances[from - 1] -= amount;
        balances[to - 1] += amount;
        return true;
    }

    public boolean deposit(int account, long amount) {
        if (!valid(account)) return false;
        balances[account - 1] += amount;
        return true;
    }

    public boolean withdraw(int account, long amount) {
        if (!valid(account)) return false;
        if (balances[account - 1] < amount) return false;
        balances[account - 1] -= amount;
        return true;
    }
}
