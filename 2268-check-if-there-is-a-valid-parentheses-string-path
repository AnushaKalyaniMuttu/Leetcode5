import java.util.*;

class Solution {
    public int minimumKeypresses(String s) {
        int[] freq = new int[26];

        for (char c : s.toCharArray()) {
            freq[c - 'a']++;
        }

        Arrays.sort(freq);

        int ans = 0;
        int press = 1;
        int used = 0;

        for (int i = 25; i >= 0; i--) {
            if (freq[i] == 0) break;

            ans += freq[i] * press;
            used++;

            if (used == 9) {
                used = 0;
                press++;
            }
        }

        return ans;
    }
}
