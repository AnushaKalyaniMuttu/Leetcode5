class Solution {
    public int minimumSplits(int[] nums) {
        int ans = 1;
        int g = nums[0];

        for (int i = 1; i < nums.length; i++) {
            g = gcd(g, nums[i]);

            if (g == 1) {
                ans++;
                g = nums[i];
            }
        }

        return ans;
    }

    private int gcd(int a, int b) {
        while (b != 0) {
            int t = a % b;
            a = b;
            b = t;
        }
        return a;
    }
}
