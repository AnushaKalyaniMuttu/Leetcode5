class Solution {
    public long countSubarrays(int[] nums) {
        long res = 0;
        int len = 1;

        for (int i = 1; i < nums.length; i++) {
            if (nums[i] > nums[i - 1]) {
                len++;
            } else {
                res += (long) len * (len + 1) / 2;
                len = 1;
            }
        }

        // last segment
        res += (long) len * (len + 1) / 2;

        return res;
    }
}
