class Solution {
    public int[] getAverages(int[] nums, int k) {
        int n = nums.length;
        int[] result = new int[n];
        
        // Fill result with -1 by default
        for (int i = 0; i < n; i++) {
            result[i] = -1;
        }
        
        // Window size
        int windowSize = 2 * k + 1;
        if (windowSize > n) return result;
        
        long windowSum = 0;
        
        // First window
        for (int i = 0; i < windowSize; i++) {
            windowSum += nums[i];
        }
        
        // Place first valid average
        result[k] = (int)(windowSum / windowSize);
        
        // Slide the window
        for (int i = windowSize; i < n; i++) {
            windowSum += nums[i];                  // add next
            windowSum -= nums[i - windowSize];     // remove old
            
            result[i - k] = (int)(windowSum / windowSize);
        }
        
        return result;
    }
}
