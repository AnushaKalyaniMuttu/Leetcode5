import java.util.*;

class Solution {
    public int kIncreasing(int[] arr, int k) {
        int n = arr.length;
        int operations = 0;

        for (int i = 0; i < k; i++) {
            List<Integer> group = new ArrayList<>();

            // build group
            for (int j = i; j < n; j += k) {
                group.add(arr[j]);
            }

            // find LNDS length
            operations += group.size() - longestNonDecreasing(group);
        }

        return operations;
    }

    private int longestNonDecreasing(List<Integer> list) {
        List<Integer> lis = new ArrayList<>();

        for (int num : list) {
            int idx = upperBound(lis, num);
            if (idx == lis.size()) {
                lis.add(num);
            } else {
                lis.set(idx, num);
            }
        }

        return lis.size();
    }

    // upper_bound: first index where value > target
    private int upperBound(List<Integer> list, int target) {
        int left = 0, right = list.size();

        while (left < right) {
            int mid = (left + right) / 2;
            if (list.get(mid) <= target) {
                left = mid + 1;
            } else {
                right = mid;
            }
        }

        return left;
    }
}
