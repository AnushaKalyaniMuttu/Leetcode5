import java.util.Arrays;

class Solution {
    public int latestTimeCatchTheBus(int[] buses, int[] passengers, int capacity) {
        Arrays.sort(buses);
        Arrays.sort(passengers);

        int i = 0;
        int n = passengers.length;

        for (int bus : buses) {
            int count = 0;
            while (i < n && passengers[i] <= bus && count < capacity) {
                i++;
                count++;
            }
        }

        int lastBus = buses[buses.length - 1];
        int lastPassenger = i - 1;
        int seatsFilled = 0;

        i = 0;
        for (int b = 0; b < buses.length; b++) {
            seatsFilled = 0;
            while (i < n && passengers[i] <= buses[b] && seatsFilled < capacity) {
                i++;
                seatsFilled++;
            }
        }

        int ans = (seatsFilled < capacity) ? lastBus : passengers[lastPassenger];

        int idx = Arrays.binarySearch(passengers, ans);
        while (idx >= 0) {
            ans--;
            idx = Arrays.binarySearch(passengers, ans);
        }

        return ans;
    }
}
