class Solution {
    public int partitionString(String s) {
        boolean[] seen = new boolean[26];
        int ans = 1;

        for (char c : s.toCharArray()) {
            int idx = c - 'a';

            if (seen[idx]) {
                ans++;
                seen = new boolean[26];
            }

            seen[idx] = true;
        }

        return ans;
    }
}
