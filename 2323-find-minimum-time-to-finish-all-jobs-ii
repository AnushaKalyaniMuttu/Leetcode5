import java.util.Arrays;

class Solution {
    public int minimumTime(int[] jobs, int[] workers) {
        Arrays.sort(jobs);
        Arrays.sort(workers);

        int ans = 0;
        for (int i = 0; i < jobs.length; i++) {
            int days = (jobs[i] + workers[i] - 1) / workers[i]; // ceil
            ans = Math.max(ans, days);
        }

        return ans;
    }
}
