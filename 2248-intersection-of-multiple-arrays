import java.util.*;

class Solution {
    public List<Integer> intersection(int[][] nums) {
        int[] count = new int[1001];

        for (int[] arr : nums) {
            for (int num : arr) {
                count[num]++;
            }
        }

        List<Integer> ans = new ArrayList<>();

        for (int num = 1; num <= 1000; num++) {
            if (count[num] == nums.length) {
                ans.add(num);
            }
        }

        return ans;
    }
}
