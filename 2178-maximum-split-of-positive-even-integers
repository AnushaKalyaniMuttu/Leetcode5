import java.util.*;

class Solution {
    public List<Long> maximumEvenSplit(long finalSum) {
        List<Long> result = new ArrayList<>();

        // If odd, not possible
        if (finalSum % 2 != 0) return result;

        long curr = 2;

        while (finalSum >= curr) {
            result.add(curr);
            finalSum -= curr;
            curr += 2;
        }

        // Add leftover to last element
        if (!result.isEmpty()) {
            long last = result.get(result.size() - 1);
            result.set(result.size() - 1, last + finalSum);
        }

        return result;
    }
}
