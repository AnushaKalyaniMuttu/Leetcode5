class Solution {
    public int numOfPairs(String[] words, String target) {
        int n = target.length();
        int answer = 0;

        for (int i = 0; i < words.length; i++) {
            String left = words[i];

            if (!target.startsWith(left)) continue;

            String needed = target.substring(left.length());

            for (int j = 0; j < words.length; j++) {
                if (i == j) continue;
                if (words[j].equals(needed)) {
                    answer++;
                }
            }
        }
        return answer;
    }
}
