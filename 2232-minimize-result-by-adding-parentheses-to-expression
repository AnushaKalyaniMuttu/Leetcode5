class Solution {
    public String minimizeResult(String expression) {
        String[] parts = expression.split("\\+");
        String left = parts[0];
        String right = parts[1];

        int minValue = Integer.MAX_VALUE;
        String answer = "";

        for (int i = 0; i < left.length(); i++) {
            for (int j = 1; j <= right.length(); j++) {
                String a = left.substring(0, i);
                String b = left.substring(i);
                String c = right.substring(0, j);
                String d = right.substring(j);

                int outsideLeft = a.isEmpty() ? 1 : Integer.parseInt(a);
                int insideLeft = Integer.parseInt(b);
                int insideRight = Integer.parseInt(c);
                int outsideRight = d.isEmpty() ? 1 : Integer.parseInt(d);

                int value = outsideLeft * (insideLeft + insideRight) * outsideRight;

                if (value < minValue) {
                    minValue = value;
                    answer = a + "(" + b + "+" + c + ")" + d;
                }
            }
        }

        return answer;
    }
}
