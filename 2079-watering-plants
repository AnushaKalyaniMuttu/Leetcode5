class Solution {
    public int wateringPlants(int[] plants, int capacity) {
        int steps = 0;
        int water = capacity;

        for (int i = 0; i < plants.length; i++) {
            // If not enough water, go back and refill
            if (water < plants[i]) {
                steps += 2 * i;  // go back and return
                water = capacity;
            }

            // Water the plant
            water -= plants[i];
            steps += 1;  // move to this plant
        }

        return steps;
    }
}
