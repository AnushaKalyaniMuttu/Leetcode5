class Solution {
    public int minSteps(String s, String t) {
        int[] freq = new int[26];

        // Count characters in s
        for (char c : s.toCharArray()) {
            freq[c - 'a']++;
        }

        // Subtract characters in t
        for (char c : t.toCharArray()) {
            freq[c - 'a']--;
        }

        int steps = 0;

        // Total difference
        for (int f : freq) {
            steps += Math.abs(f);
        }

        return steps;
    }
}
