class Solution {
    public int maximumsSplicedArray(int[] nums1, int[] nums2) {
        return Math.max(maxScore(nums1, nums2), maxScore(nums2, nums1));
    }

    private int maxScore(int[] base, int[] other) {
        int sum = 0;
        int currGain = 0;
        int maxGain = 0;

        for (int i = 0; i < base.length; i++) {
            sum += base[i];

            int gain = other[i] - base[i];
            currGain = Math.max(gain, currGain + gain);
            maxGain = Math.max(maxGain, currGain);
        }

        return sum + maxGain;
    }
}
