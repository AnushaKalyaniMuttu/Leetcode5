class Solution {
    public boolean checkAlmostEquivalent(String word1, String word2) {
        int[] diff = new int[26];

        for (char c : word1.toCharArray()) {
            diff[c - 'a']++;
        }

        for (char c : word2.toCharArray()) {
            diff[c - 'a']--;
        }

        for (int i = 0; i < 26; i++) {
            if (Math.abs(diff[i]) > 3) {
                return false;
            }
        }

        return true;
    }
}
