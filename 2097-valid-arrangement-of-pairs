import java.util.*;

class Solution {
    public int[][] validArrangement(int[][] pairs) {
        Map<Integer, Deque<Integer>> graph = new HashMap<>();
        Map<Integer, Integer> indegree = new HashMap<>();
        Map<Integer, Integer> outdegree = new HashMap<>();

        // Build graph
        for (int[] p : pairs) {
            graph.computeIfAbsent(p[0], k -> new ArrayDeque<>()).add(p[1]);
            outdegree.put(p[0], outdegree.getOrDefault(p[0], 0) + 1);
            indegree.put(p[1], indegree.getOrDefault(p[1], 0) + 1);
        }

        // Find start node
        int start = pairs[0][0];
        for (int node : graph.keySet()) {
            int out = outdegree.getOrDefault(node, 0);
            int in = indegree.getOrDefault(node, 0);
            if (out - in == 1) {
                start = node;
                break;
            }
        }

        List<int[]> result = new ArrayList<>();
        dfs(start, graph, result);

        // Reverse result
        Collections.reverse(result);

        return result.toArray(new int[result.size()][]);
    }

    private void dfs(int node, Map<Integer, Deque<Integer>> graph, List<int[]> result) {
        Deque<Integer> neighbors = graph.get(node);

        while (neighbors != null && !neighbors.isEmpty()) {
            int next = neighbors.pollFirst();
            dfs(next, graph, result);
            result.add(new int[]{node, next});
        }
    }
}
