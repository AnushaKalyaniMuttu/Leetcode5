import java.util.*;

class Encrypter {
    private Map<Character, String> encMap;
    private Map<String, Integer> freqMap;

    public Encrypter(char[] keys, String[] values, String[] dictionary) {
        encMap = new HashMap<>();
        freqMap = new HashMap<>();

        // Build encryption map
        for (int i = 0; i < keys.length; i++) {
            encMap.put(keys[i], values[i]);
        }

        // Precompute encrypted dictionary frequencies
        for (String word : dictionary) {
            String encrypted = encrypt(word);
            freqMap.put(encrypted, freqMap.getOrDefault(encrypted, 0) + 1);
        }
    }

    public String encrypt(String word1) {
        StringBuilder sb = new StringBuilder();

        for (char ch : word1.toCharArray()) {
            if (!encMap.containsKey(ch)) return "";
            sb.append(encMap.get(ch));
        }

        return sb.toString();
    }

    public int decrypt(String word2) {
        return freqMap.getOrDefault(word2, 0);
    }
}
