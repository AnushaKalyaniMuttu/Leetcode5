import java.util.*;

class Solution {
    public List<Integer> airportWithMostTraffic(int[][] flights) {
        Map<Integer, Integer> map = new HashMap<>();

        // Step 1: accumulate traffic
        for (int[] f : flights) {
            int from = f[0];
            int to = f[1];
            int count = f[2];

            map.put(from, map.getOrDefault(from, 0) + count);
            map.put(to, map.getOrDefault(to, 0) + count);
        }

        // Step 2: find max traffic
        int max = 0;
        for (int val : map.values()) {
            max = Math.max(max, val);
        }

        // Step 3: collect answer
        List<Integer> res = new ArrayList<>();
        for (int key : map.keySet()) {
            if (map.get(key) == max) {
                res.add(key);
            }
        }

        Collections.sort(res);
        return res;
    }
}
