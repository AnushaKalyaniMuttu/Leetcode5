class Solution {
    public long taskSchedulerII(int[] tasks, int space) {
        Map<Integer, Long> lastDay = new HashMap<>();
        long day = 0;

        for (int task : tasks) {
            day++;

            if (lastDay.containsKey(task)) {
                long nextAllowed = lastDay.get(task) + space + 1;
                day = Math.max(day, nextAllowed);
            }

            lastDay.put(task, day);
        }

        return day;
    }
}
