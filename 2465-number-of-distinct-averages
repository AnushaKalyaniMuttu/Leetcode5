import java.util.*;

class Solution {
    public int distinctAverages(int[] nums) {
        Arrays.sort(nums);

        Set<Integer> set = new HashSet<>();

        int left = 0;
        int right = nums.length - 1;

        while (left < right) {
            // Store doubled average to avoid precision problems
            set.add(nums[left] + nums[right]);
            left++;
            right--;
        }

        return set.size();
    }
}
