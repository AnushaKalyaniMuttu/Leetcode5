class Solution {
    public long appealSum(String s) {
        long ans = 0;
        long curr = 0;
        int[] last = new int[26];

        for (int i = 0; i < 26; i++) {
            last[i] = -1;
        }

        for (int i = 0; i < s.length(); i++) {
            int ch = s.charAt(i) - 'a';

            curr += i - last[ch];
            ans += curr;

            last[ch] = i;
        }

        return ans;
    }
}
